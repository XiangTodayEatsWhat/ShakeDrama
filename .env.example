# 复制为 .env 后使用。请勿提交 .env。
# 端口
AXIS_API_PORT=8502

# 说明：本项目不内置任何域名、Token、样本库或历史剧本。
# 首次进入网页后，请先注册用户名；然后在“新建剧本”页面新增你的接口配置方案。
# 每个配置方案都需要填写：配置名称、API Key、Base URL、模型名称。

# 如需保留一组默认环境变量方式，也可在此填写（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
WLAI_API_KEY=
WLAI_BASE_URL=
WLAI_MODEL=
